{
  "name": "autotempest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ingest": "tsx lib/ingest/runIngest.ts",
    "ingest:tipcars": "tsx lib/ingest/runIngest.ts --source=tipcars",
    "backfill:engine-keys": "tsx lib/maintenance/backfillEngineKeys.ts",
    "crawl": "tsx lib/ingest/runDeepCrawl.ts",
    "crawl:skoda": "tsx lib/ingest/runDeepCrawl.ts --brand=skoda",
    "crawl:sauto": "tsx lib/ingest/runDeepCrawl.ts --source=sauto",
    "ingest:models": "tsx lib/ingest/runIngest.ts --mode=models",
    "crawl:fast": "tsx lib/ingest/runDeepCrawl.ts --sauto-only --pages=2",
    "crawl:all": "tsx lib/ingest/runDeepCrawl.ts --pages=5",
    "crawl:tutut": "tsx scripts/crawl-tutut.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.4.2",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
